# LastMile-Sec .gitignore

# Large files (GitHub limit is 100MB)
*.mp4
*.mov
*.avi
*.mkv

# Virtual environment
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Test data - DO NOT commit client files
data/raw/*
data/processed/*
data/cache/*
data/remediated/*
data/correlate/*
!data/raw/.gitkeep

# Processed output (may contain client info)
data/processed/*
!data/processed/.gitkeep

# Mapped output (contains enriched findings with MITRE IDs)
data/mapped/*
!data/mapped/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Environment variables (API keys)
.env
.env.local
.env.example

# Pytest cache
.pytest_cache/
.coverage
htmlcov/

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Build artifacts
dist/
build/
*.egg-info/

#docker image
docker-compose.yml

# Neo4j data and logs
neo4j/data/
neo4j/logs/
neo4j/import/
neo4j/plugins/
